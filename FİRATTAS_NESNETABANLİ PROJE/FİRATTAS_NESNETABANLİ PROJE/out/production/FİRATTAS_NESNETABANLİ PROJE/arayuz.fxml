<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<HBox spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="AnaSayfaController">
    <children>
        <VBox spacing="15.0" prefWidth="300.0" style="-fx-background-color: #f4f4f4; -fx-padding: 20;">
            <children>
                <Label text="Cezaevi Yönetimi" textFill="#2c3e50"><font><Font name="System Bold" size="20.0" /></font></Label>
                <Separator prefWidth="200.0" />
                <Label text="Mahkum ID:" /><TextField fx:id="txtId" />
                <Label text="Adı Soyadı:" /><TextField fx:id="txtAdSoyad" />
                <Label text="Suçu:" /><TextField fx:id="txtSuc" />
                <Label text="Ceza Süresi (Yıl):" /><TextField fx:id="txtSure" />
                <Separator prefWidth="200.0" />
                <Button fx:id="btnEkle" maxWidth="Infinity" onAction="#mahkumEkle" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" text="Mahkum Ekle" />
                <Button fx:id="btnSil" maxWidth="Infinity" onAction="#mahkumSil" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Seçili Mahkumu Tahliye Et" />
            </children>
        </VBox>
        <VBox spacing="10.0" HBox.hgrow="ALWAYS" style="-fx-padding: 20;">
            <children>
                <Label text="Kayıtlı Mahkum Listesi" textFill="#34495e"><font><Font name="System Bold" size="16.0" /></font></Label>
                <TableView fx:id="tabloMahkum" onMouseClicked="#tabloGenelTiklama" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="80.0" text="ID" />
                        <TableColumn fx:id="colAdSoyad" prefWidth="150.0" text="Adı Soyadı" />
                        <TableColumn fx:id="colSuc" prefWidth="120.0" text="Suçu" />
                        <TableColumn fx:id="colSure" prefWidth="100.0" text="Ceza Süresi" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</HBox>